# =========================================================================
# dart-search backend 환경변수 예시 파일
# 실제 값을 채운 뒤 파일명을 `.env` 로 복사해서 사용할 것.
# 절대 실제 키 값을 커밋하지 말 것 (.gitignore에 .env 등록되어 있음).
# =========================================================================

# --- OpenDART API 키 ---
# 발급: https://opendart.fss.or.kr/ (회원가입 후 [인증키 신청/관리])
DART_API_KEY=

# --- 공공데이터포털 금융위원회_기업기본정보 API 키 ---
# 발급: https://www.data.go.kr/ (활용신청 → 금융위원회_기업기본정보조회서비스)
# M1 스파이크(대응1/2 채택 결정) 및 §4-1 지역 필터 대응1 채택 시 사용.
DATA_GO_KR_API_KEY=

# --- DB ---
DATABASE_URL=sqlite:///./dart_search.db

# --- 로컬 캐시/파일 저장 경로 ---
CORP_CACHE_DIR=./data/corp_cache
DOCUMENT_CACHE_DIR=./data/documents

# --- OpenDART API 호출 정책 (상세개발계획.md §4-5) ---
# 일일 호출 한도 20,000건 중 여유분을 남긴 안전 상한
DAILY_QUOTA_LIMIT=19000
# 요청 간 기본 딜레이(초)
REQUEST_DELAY_SEC=0.1
# 429/5xx 재시도 최대 횟수 (지수 백오프)
MAX_RETRIES=3

# --- 캐시 갱신 주기 (일) ---
# corp_cache(corpCode.xml) 갱신 주기
CORP_CACHE_TTL_DAYS=7
# corp_profiles(기업개황) 전역 캐시 갱신 주기
CORP_PROFILE_TTL_DAYS=180
