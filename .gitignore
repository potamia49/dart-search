# --- 환경변수 / 비밀정보 ---
.env
backend/.env

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/

# --- DB / 로컬 캐시 데이터 ---
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.bak.*
*.bak
backend/data/corp_cache/*
!backend/data/corp_cache/.gitkeep
backend/data/documents/*
!backend/data/documents/.gitkeep

# --- Node / 프론트엔드 ---
node_modules/
dist/
.vite/

# --- 에디터/OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- 로그 ---
*.log

# --- PyInstaller 빌드 산출물 (실행파일은 소스가 아니라 빌드 결과물) ---
backend/build/
backend/dist/
backend/*.spec
backend/exe_test*/
